{
  "name": "thrive-fertilizing",
  "version": "0.1.0",
  "description": "AI-powered business command center for fertilizing operations",
  "private": true,
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd src/frontend && npm run dev",
    "dev:backend": "cd src/backend && venv/bin/uvicorn main:app --reload --port 4000",
    "stop:backend": "lsof -ti:4000 | xargs kill -9 2>/dev/null || true",
    "migrate": "cd src/backend && venv/bin/alembic upgrade head"
  },
  "keywords": [
    "ai",
    "business-automation",
    "crm",
    "dashboard"
  ],
  "author": "",
  "license": "PROPRIETARY",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
